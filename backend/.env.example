PORT=5000
FLASK_DEBUG=1
MODEL_PATH=plant_disease_fewshot_model.h5
LABELS_PATH=labels.json
# Comma-separated origins (localhost and 127.0.0.1 are different — include both for Vite)
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# Set to 1 to skip TensorFlow model load (mock predictions)
MOCK_PREDICTIONS=0
